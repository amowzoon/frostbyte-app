{
  "expo": {
    "name": "frostbyte-app",
    "slug": "frostbyte-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.frostbyte.alertapp",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "FrostByte uses your location to show nearby ice alerts on the map.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "FrostByte uses your location in the background to warn you when you are approaching ice, even when the app is closed.",
        "NSLocationAlwaysUsageDescription": "FrostByte uses your location in the background to warn you when you are approaching ice, even when the app is closed.",
        "UIBackgroundModes": [
          "location",
          "fetch",
          "location",
          "fetch"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.frostbyte.alertapp",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-task-manager",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "FrostByte uses your location in the background to warn you when you are approaching ice, even when the app is closed.",
          "locationAlwaysPermission": "FrostByte uses your location in the background to warn you when you are approaching ice.",
          "locationWhenInUsePermission": "FrostByte uses your location to show nearby ice alerts."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1a1a2e"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "bb7dd623-b3c2-41e9-9d58-17867f4b76bc"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/bb7dd623-b3c2-41e9-9d58-17867f4b76bc"
    }
  }
}